<odoo>
    <data>
        <record id="equipment_management_category" model="ir.module.category">
            <field name="name">Enterprise Equipment Management</field>
            <field name="sequence">100</field>
        </record>

        <record id="equipment_user_group" model="res.groups">
            <field name="name">User</field>
            <field name="category_id" ref="equipment_management_category"/>
        </record>

        <record id="equipment_manager_group" model="res.groups">
            <field name="name">Manager</field>
            <field name="category_id" ref="equipment_management_category"/>
            <field name="implied_ids" eval="[(4, ref('equipment_user_group'))]"/>
        </record>
    </data>
</odoo>
