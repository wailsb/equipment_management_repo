<odoo>
    <data>
        <!-- Log Tree View -->
        <record id="equipment_log_tree_view" model="ir.ui.view">
            <field name="name">equipment.log.tree.view</field>
            <field name="model">equipment.log</field>
            <field name="arch" type="xml">
                <list string="History" create="false" edit="false" delete="false">
                    <field name="date"/>
                    <field name="user_id"/>
                    <field name="log_type" widget="badge"
                           decoration-info="log_type == 'equipment'"
                           decoration-success="log_type == 'assignment'"/>
                    <field name="action" widget="badge"/>
                    <field name="equipment_id" string="Equipment"/>
                    <field name="assignment_id" string="Details" optional="show"/>
                    <field name="description"/>
                </list>
            </field>
        </record>

        <!-- Log Search View -->
        <record id="equipment_log_search_view" model="ir.ui.view">
            <field name="name">equipment.log.search.view</field>
            <field name="model">equipment.log</field>
            <field name="arch" type="xml">
                <search string="History">
                    <field name="equipment_id"/>
                    <field name="user_id"/>
                    <field name="description"/>
                    <separator/>
                    <filter name="equipment_logs" string="Equipment Logs" domain="[('log_type', '=', 'equipment')]"/>
                    <filter name="assignment_logs" string="Assignment Logs" domain="[('log_type', '=', 'assignment')]"/>
                    <separator/>
                    <filter name="today" string="Today" domain="[('date', '&gt;=', (context_today()).strftime('%Y-%m-%d'))]"/>
                    <filter name="this_week" string="This Week" domain="[('date', '&gt;=', (context_today() - datetime.timedelta(days=7)).strftime('%Y-%m-%d'))]"/>
                    <separator/>
                    <group expand="0" string="Group By">
                        <filter name="group_by_type" string="Log Type" context="{'group_by': 'log_type'}"/>
                        <filter name="group_by_action" string="Action" context="{'group_by': 'action'}"/>
                        <filter name="group_by_user" string="User" context="{'group_by': 'user_id'}"/>
                        <filter name="group_by_date" string="Date" context="{'group_by': 'date:day'}"/>
                        <filter name="group_by_equipment" string="Equipment" context="{'group_by': 'equipment_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Log Form View (read-only detail view) -->
        <record id="equipment_log_form_view" model="ir.ui.view">
            <field name="name">equipment.log.form.view</field>
            <field name="model">equipment.log</field>
            <field name="arch" type="xml">
                <form string="Log Entry" create="false" edit="false" delete="false">
                    <sheet>
                        <group>
                            <group string="Log Info">
                                <field name="date"/>
                                <field name="user_id"/>
                                <field name="log_type"/>
                                <field name="action"/>
                            </group>
                            <group string="Related Records">
                                <field name="equipment_id"/>
                                <field name="assignment_id"/>
                            </group>
                        </group>
                        <group string="Description">
                            <field name="description" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Actions for different log views -->
        <record id="action_equipment_log_all" model="ir.actions.act_window">
            <field name="name">All History</field>
            <field name="res_model">equipment.log</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="equipment_log_search_view"/>
        </record>

        <record id="action_equipment_log_equipment" model="ir.actions.act_window">
            <field name="name">Equipment Logs</field>
            <field name="res_model">equipment.log</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('log_type', '=', 'equipment')]</field>
            <field name="search_view_id" ref="equipment_log_search_view"/>
        </record>

        <record id="action_equipment_log_assignment" model="ir.actions.act_window">
            <field name="name">Assignment Logs</field>
            <field name="res_model">equipment.log</field>
            <field name="view_mode">list,form</field>
            <field name="domain">[('log_type', '=', 'assignment')]</field>
            <field name="search_view_id" ref="equipment_log_search_view"/>
        </record>
    </data>
</odoo>
