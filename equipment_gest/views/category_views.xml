<odoo>
    <data>
        <!-- Category Form View -->
        <record id="equipment_category_form_view" model="ir.ui.view">
            <field name="name">equipment.category.form.view</field>
            <field name="model">equipment.category</field>
            <field name="arch" type="xml">
                <form string="Equipment Category">
                    <header>
                        <button name="action_save_and_close" string="Save &amp; Close" type="object" class="btn-primary"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" placeholder="Category Name"/>
                            </h1>
                        </div>
                        <notebook>
                            <page string="Equipment Items">
                                <field name="equipment_ids">
                                    <list>
                                        <field name="name"/>
                                        <field name="serial_no"/>
                                        <field name="status" widget="badge"
                                               decoration-success="status == 'available'"
                                               decoration-info="status == 'assigned'"
                                               decoration-warning="status == 'maintenance'"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- Category Tree View -->
        <record id="equipment_category_tree_view" model="ir.ui.view">
            <field name="name">equipment.category.tree.view</field>
            <field name="model">equipment.category</field>
            <field name="arch" type="xml">
                <list string="Equipment Categories">
                    <header>
                        <button name="%(action_equipment_import_wizard_category)d" string="Import Spreadsheet" type="action" class="btn-secondary"/>
                    </header>
                    <field name="name"/>
                    <field name="equipment_count" string="# Equipment"/>
                </list>
            </field>
        </record>

        <!-- Category Search View -->
        <record id="equipment_category_search_view" model="ir.ui.view">
            <field name="name">equipment.category.search.view</field>
            <field name="model">equipment.category</field>
            <field name="arch" type="xml">
                <search string="Equipment Categories">
                    <field name="name"/>
                </search>
            </field>
        </record>

        <!-- Category Action -->
        <record id="action_equipment_category" model="ir.actions.act_window">
            <field name="name">Categories</field>
            <field name="res_model">equipment.category</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>
