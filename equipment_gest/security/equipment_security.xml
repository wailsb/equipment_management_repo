<odoo>
    <data>
        <!-- Module Category -->
        <record id="equipment_management_category" model="ir.module.category">
            <field name="name">Equipment Management</field>
            <field name="sequence">100</field>
        </record>

        <!-- Privileges for Odoo 19 -->
        <record id="equipment_privilege_user" model="res.groups.privilege">
            <field name="name">Operational User Privilege</field>
            <field name="category_id" ref="equipment_management_category"/>
        </record>

        <record id="equipment_privilege_manager" model="res.groups.privilege">
            <field name="name">Manager Privilege</field>
            <field name="category_id" ref="equipment_management_category"/>
        </record>

        <!-- Operational User: daily assignment management -->
        <record id="equipment_user_group" model="res.groups">
            <field name="name">Operational User</field>
            <field name="privilege_id" ref="equipment_privilege_user"/>
        </record>

        <!-- Manager: full equipment supervision -->
        <record id="equipment_manager_group" model="res.groups">
            <field name="name">Manager</field>
            <field name="privilege_id" ref="equipment_privilege_manager"/>
            <field name="implied_ids" eval="[(4, ref('equipment_user_group'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
